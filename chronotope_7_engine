module chronotope_7_engine (
    input  logic       clk,
    input  logic       rst_n,
    input  logic       step,
    output logic [2:0] state,
    output logic [1:0] rule,
    output logic [1:0] macro_level,
    output logic       is_inversion,
    output logic       is_enversion,
    output logic       error_detected,
    output logic       invariant_closed
);

    logic [2:0] next_state;

    assign next_state[0] = state[2];
    assign next_state[1] = state[0];
    assign next_state[2] = state[1] ^ state[0];

    always_ff @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            state       <= 3'b001;
            rule        <= 2'd0;
            macro_level <= 2'd1;
        end else if (step) begin
            state <= next_state;
            if (rule == 2'd3) begin
                rule <= 2'd0;
                macro_level <= (macro_level == 2'd3) ? 2'd1 : macro_level + 2'd1;
            end else begin
                rule <= rule + 2'd1;
            end
        end
    end

    assign is_inversion  = rule[0];
    assign is_enversion  = (rule == 2'd3);
    assign error_detected = (state == 3'b000);
    assign invariant_closed = (macro_level != 2'd0) && !error_detected;
endmodule
